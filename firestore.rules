rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNumeric(val) {
      return val is number;
    }

    // Collection match for users
    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId)
                    && request.resource.data.keys().hasAll(['id', 'name', 'monthlyAllowance', 'allowanceDay', 'joinedAt'])
                    && request.resource.data.keys().size() <= 6
                    && request.resource.data.id == request.auth.uid
                    && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100
                    && isNumeric(request.resource.data.monthlyAllowance) && request.resource.data.monthlyAllowance >= 0
                    && request.resource.data.allowanceDay is number && request.resource.data.allowanceDay >= 1 && request.resource.data.allowanceDay <= 31;
      allow update: if isSignedIn() && isOwner(userId)
                    && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100
                    && isNumeric(request.resource.data.monthlyAllowance) && request.resource.data.monthlyAllowance >= 0
                    && request.resource.data.allowanceDay is number && request.resource.data.allowanceDay >= 1 && request.resource.data.allowanceDay <= 31;
      allow delete: if false;
    }

    // Collection match for expenses
    match /expenses/{expenseId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId)
                    && request.resource.data.keys().hasAll(['id', 'userId', 'storeName', 'totalAmount', 'category', 'items', 'date', 'isAiScanned'])
                    && request.resource.data.storeName is string && request.resource.data.storeName.size() > 0 && request.resource.data.storeName.size() <= 200
                    && isNumeric(request.resource.data.totalAmount)
                    && request.resource.data.category is string && request.resource.data.category.size() <= 50
                    && request.resource.data.items is list
                    && request.resource.data.date is string && request.resource.data.date.size() <= 50;
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isOwner(request.resource.data.userId)
                    && request.resource.data.storeName is string && request.resource.data.storeName.size() > 0 && request.resource.data.storeName.size() <= 200
                    && isNumeric(request.resource.data.totalAmount)
                    && request.resource.data.category is string && request.resource.data.category.size() <= 50
                    && request.resource.data.items is list
                    && request.resource.data.date is string && request.resource.data.date.size() <= 50;
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Collection match for savings goals
    match /goals/{goalId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(request.resource.data.userId)
                    && request.resource.data.keys().hasAll(['id', 'userId', 'title', 'targetAmount', 'currentAmount', 'category', 'createdAt', 'targetMonths'])
                    && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                    && isNumeric(request.resource.data.targetAmount) && request.resource.data.targetAmount >= 0
                    && isNumeric(request.resource.data.currentAmount) && request.resource.data.currentAmount >= 0
                    && request.resource.data.category is string && request.resource.data.category.size() <= 50
                    && request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 50
                    && isNumeric(request.resource.data.targetMonths) && request.resource.data.targetMonths >= 1;
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isOwner(request.resource.data.userId)
                    && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                    && isNumeric(request.resource.data.targetAmount) && request.resource.data.targetAmount >= 0
                    && isNumeric(request.resource.data.currentAmount) && request.resource.data.currentAmount >= 0
                    && request.resource.data.category is string && request.resource.data.category.size() <= 50
                    && request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 50
                    && isNumeric(request.resource.data.targetMonths) && request.resource.data.targetMonths >= 1;
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
  }
}
